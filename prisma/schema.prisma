generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name")
  email     String
  company   String?
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("form_submissions")
}
